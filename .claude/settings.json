{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/validate-before-commit.sh",
            "statusMessage": "Validating before commit..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(pnpm run validate:*)",
      "Bash(pnpm run type-check:*)",
      "Bash(pnpm run lint:*)",
      "Bash(pnpm run format:*)",
      "Bash(pnpm run test:*)",
      "Bash(pnpm run build:*)",
      "Skill(*)"
    ]
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": []
}
